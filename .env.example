# Telegram — בוט משתמשים (חובה)
TELEGRAM_BOT_TOKEN=

# בוט אדמין — יצירת קופונים (אופציונלי)
ADMIN_BOT_TOKEN=
ADMIN_USER_IDS=

# Gemini Vision (חובה)
GEMINI_VISION_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
VISION_QUALITY_MODEL=gemini-2.5-flash

BOT_DISPLAY_NAME=Beam Solver

# Vision / draft
VISION_ASYNC_ENABLED=1
VISION_FAST_MODE=1
DRAFT_APPROVAL_MODE=1
VISION_FAST_FALLBACK_STAGED=0
VISION_QUALITY_RETRY=0
VISION_LOADS_REFINE=0
VISION_OVERLOAD_FALLBACK=0
GEMINI_MAX_RETRIES_PER_MODEL=1

# Railway — volume mount at /data
COUPON_DB_PATH=/data/coupons.db

# Payment
BIT_PHONE=
PAYMENT_CONFIRM_WHATSAPP_URL=

